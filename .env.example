# SovereignLex Configuration
# Copy this to .env and fill in your keys

# DeepSeek API (recommended for best legal reasoning quality, no GPU needed)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek/deepseek-chat

# Alternative: OpenAI (if you prefer)
# OPENAI_API_KEY=your_openai_api_key_here

# No config needed for Ollama (local, sovereign, needs GPU for speed)
# Just run: ollama pull llama3.1:8b
